{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "gastro-manager",
	"pages_build_output_dir": "./dist",
	"compatibility_date": "2025-06-17",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "gastro-manager-db",
			"database_id": "3a05795f-4483-4bd2-9b0b-ef88899c2e1f"
		}
	],
	"r2_buckets": [
		{
			"binding": "R2_BUCKET",
			"bucket_name": "gastro-manager-files"
		}
	],
	"triggers": {
		"crons": ["0 3 1 * *"]
	},
	"kv_namespaces": [
		{
			"binding": "CACHE",
			"id": "45a74613e74f4830ae1e435a7761cf73",
			"preview_id": "1e0f80d0290e4bd49518855f82281df1"
		}
	]
}